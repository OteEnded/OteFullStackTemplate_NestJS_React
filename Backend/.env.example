# Environment variable overrides for config.json.
#
# Every value here is OPTIONAL. config.json is the base; any variable set here
# (or in the real environment) overrides the matching config.json value. This is
# how you inject production secrets without committing them.
#
# Copy to `.env` only if you want file-based overrides locally. In production,
# prefer setting these in the real environment / container, not a file.

# App
# PORT=3000

# CORS (comma-separated). Use * to allow all origins.
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# Logging
# LOG_REQUESTS=true

# Database
# DATABASE_ENABLED=true
# DATABASE_SYNCHRONIZE=false        # keep false in production; use migrations
# DATABASE_LOGGING=false
# DATABASE_SEED_TEMPLATE_ITEMS=false
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=
# DATABASE_SCHEMA=public          # project schema (connection default for entities)
# DATABASE_SCHEMA_PARENT=public   # parent schema (for entities pinned to @Entity({ schema: SCHEMAS.parent }))
